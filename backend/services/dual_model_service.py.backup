"""
DualModelChatService - 双模型路由服务

根据查询复杂度自动选择使用 7B 或 14B 模型：
- 简单查询 → 7B 模型（快速响应）
- 复杂查询 → 14B 模型（更准确的分析和计算）

用户也可以手动指定使用哪个模型。
支持错误恢复、自动降级和重试机制。
"""

import logging
import time
import asyncio
from typing import Dict, Any, Optional, List, Callable, Union
from langchain_ollama import ChatOllama
from langchain_core.language_models.chat_models import BaseChatModel

from .complexity_analyzer import (
    QueryComplexityAnalyzer,
    get_complexity_analyzer,
    ComplexityResult,
    QueryIntent
)

logger = logging.getLogger(__name__)

# 错误处理配置
ERROR_HANDLING_CONFIG = {
    "max_retries": 2,
    "retry_delay": 1.0,
    "timeout": 60,
    "fallback_threshold": 3,  # 连续失败次数超过此值触发降级
    "health_check_interval": 300,  # 健康检查间隔（秒）
}

# 错误类型定义
class ModelError(Exception):
    """模型相关错误"""
    pass

class ServiceError(Exception):
    """服务相关错误"""
    pass

class InitializationError(Exception):
    """初始化错误"""
    pass


class DualModelChatService:
    """
    双模型路由服务

    管理两个 LLM 实例，根据查询复杂度自动路由
    """

    def __init__(self):
        """初始化双模型聊天服务"""
        self.llm_7b: Optional[ChatOllama] = None
        self.llm_14b: Optional[ChatOllama] = None

        self.master_graph_7b = None
        self.master_graph_14b = None

        self.hybrid_retriever = None
        self.table_analyzer = None

        self.complexity_analyzer: Optional[QueryComplexityAnalyzer] = None

        # 模型配置
        self.model_name_7b: Optional[str] = None
        self.model_name_14b: Optional[str] = None
        self.threshold: float = 0.6

        # 统计信息
        self.stats = {
            "7b_count": 0,
            "14b_count": 0,
            "total_count": 0,
            "avg_complexity": 0.0,
            "model_switches": 0,
            "error_count": 0,
            "fallback_count": 0,
            "consecutive_failures": 0
        }

        # 错误跟踪
        self.error_history = []
        self.last_health_check = 0
        self._initialized = False

    def initialize(
        self,
        ollama_base_url: str = "http://localhost:11434",
        model_name_7b: str = "qwen2.5:7b",
        model_name_14b: str = "qwen2.5:14b",  # 默认改用14b而不是32b
        threshold: float = 0.5,  # 降低阈值，让更多问题使用14b
        hybrid_retriever=None,
        table_analyzer=None,
        enable_14b: bool = True
    ):
        """
        初始化双模型服务

        Args:
            ollama_base_url: Ollama 服务地址
            model_name_7b: 7B 模型名称
            model_name_14b: 14B 模型名称
            threshold: 复杂度阈值，超过此值使用 14B
            hybrid_retriever: 混合检索器
            table_analyzer: 表格分析器
            enable_14b: 是否启用 14B 模型
        """
        try:
            logger.info("🔧 初始化 DualModelChatService...")

            self.model_name_7b = model_name_7b
            self.model_name_14b = model_name_14b
            self.threshold = threshold
            self.hybrid_retriever = hybrid_retriever
            self.table_analyzer = table_analyzer

            # 初始化复杂度分析器
            self.complexity_analyzer = QueryComplexityAnalyzer(threshold=threshold)

            # 初始化 7B 模型
            logger.info(f"📦 初始化 7B 模型: {model_name_7b}")
            try:
                self.llm_7b = ChatOllama(
                    base_url=ollama_base_url,
                    model=model_name_7b,
                    temperature=0.2,
                    num_predict=1000,
                    top_k=20,
                    top_p=0.9,
                    timeout=ERROR_HANDLING_CONFIG["timeout"]
                )
                logger.info(f"✅ 7B 模型初始化完成")
            except Exception as e:
                logger.error(f"❌ 7B 模型初始化失败: {e}")
                raise InitializationError(f"7B模型初始化失败: {e}")

            # 初始化 14B 模型（如果启用）
            if enable_14b:
                logger.info(f"📦 初始化大模型: {model_name_14b}")
                try:
                    # 根据模型名称判断是否是 32B 模型，使用不同的参数
                    is_32b_model = "32b" in model_name_14b.lower() or "deepseek-r1" in model_name_14b.lower()

                    if is_32b_model:
                        # 32B 模型参数：更精确、更长输出、更长超时
                        self.llm_14b = ChatOllama(
                            base_url=ollama_base_url,
                            model=model_name_14b,
                            temperature=0.1,  # 降低温度以获得更准确的答案
                            num_predict=3000,  # 允许更长输出
                            top_k=20,
                            top_p=0.9,
                            timeout=120  # 32B 模型需要更长的超时时间
                        )
                        logger.info(f"✅ 大模型(32B)初始化完成 - 参数: temperature=0.1, num_predict=3000, timeout=120")
                    else:
                        # 14B 模型参数
                        self.llm_14b = ChatOllama(
                            base_url=ollama_base_url,
                            model=model_name_14b,
                            temperature=0.2,
                            num_predict=2000,
                            top_k=20,
                            top_p=0.9,
                            timeout=ERROR_HANDLING_CONFIG["timeout"]
                        )
                        logger.info(f"✅ 大模型(14B)初始化完成")
                except Exception as e:
                    logger.error(f"❌ 14B 模型初始化失败: {e}")
                    logger.warning("📌 将仅使用 7B 模型")
                    self.llm_14b = None
            else:
                self.llm_14b = None
                logger.info("📌 14B 模型已禁用")

            # 初始化检索器
            if self.hybrid_retriever is None:
                try:
                    from vector_storage import VectorStorage
                    from embedding_service import EmbeddingService
                    import service_instance

                    vector_storage = VectorStorage()
                    if not vector_storage.connect():
                        raise Exception("向量存储连接失败")

                    embedding_service = EmbeddingService()
                    if not embedding_service.load_model():
                        raise Exception("嵌入模型加载失败")

                    # 设置到全局服务实例，供 document_routes.py 使用
                    service_instance.set_vector_storage(vector_storage)
                    service_instance.set_embedding_service(embedding_service)
                    logger.info("✅ 向量存储和嵌入服务已注册到全局实例")

                    from hybrid_search import HybridRetriever
                    self.hybrid_retriever = HybridRetriever(
                        embedding_service=embedding_service,
                        vector_storage=vector_storage
                    )
                    logger.info("✅ 混合检索器初始化完成")
                except Exception as e:
                    logger.error(f"❌ 混合检索器初始化失败: {e}")
                    logger.error(f"详细错误: {type(e).__name__}: {str(e)}")
                    import traceback
                    logger.error(f"堆栈跟踪:\n{traceback.format_exc()}")
                    # 关键：不要继续初始化，因为文档上传功能需要这些服务
                    raise Exception(f"向量检索服务初始化失败，文档上传功能将不可用: {e}")

            # 初始化表格分析器
            if self.table_analyzer is None:
                try:
                    from agents.enhanced_table_analyzer import get_table_analyzer
                    self.table_analyzer = get_table_analyzer()
                    logger.info("✅ 表格分析器初始化完成")
                except Exception as e:
                    logger.warning(f"⚠️ 表格分析器初始化失败: {e}")

            # 创建 MasterGraph 实例
            from langgraph_agents.master_graph import create_master_graph

            self.master_graph_7b = create_master_graph(
                llm=self.llm_7b,
                hybrid_retriever=self.hybrid_retriever,
                table_analyzer=self.table_analyzer,
                use_checkpointer=False
            )

            if self.llm_14b is not None:
                self.master_graph_14b = create_master_graph(
                    llm=self.llm_14b,
                    hybrid_retriever=self.hybrid_retriever,
                    table_analyzer=self.table_analyzer,
                    use_checkpointer=False
                )

            self._initialized = True
            logger.info("✅ DualModelChatService 初始化完成")
            logger.info(f"📊 配置: 7B={model_name_7b}, 14B={model_name_14b}, threshold={threshold}")

        except Exception as e:
            logger.error(f"❌ DualModelChatService 初始化失败: {e}")
            raise

    async def achat(
        self,
        message: str,
        session_id: Optional[str] = None,
        chat_history: Optional[List[Dict[str, str]]] = None,
        config: Optional[Dict[str, Any]] = None,
        force_model: Optional[str] = None
    ) -> Dict[str, Any]:
        """
        异步聊天

        Args:
            message: 用户消息
            session_id: 会话ID
            chat_history: 对话历史
            config: 额外配置
            force_model: 强制指定模型 ("7b" 或 "14b")

        Returns:
            响应字典，包含使用的模型信息和错误统计
        """
        if not self._initialized:
            return {
                "success": False,
                "error": "DualModelChatService 未初始化",
                "answer": "抱歉，服务尚未初始化。",
                "model_stats": {
                    "error_type": "service_uninitialized",
                    "fallback_used": True
                }
            }

        start_time = time.time()

        # 执行健康检查（如果需要）
        current_time = time.time()
        if current_time - self.last_health_check > ERROR_HANDLING_CONFIG["health_check_interval"]:
            await self._perform_health_check()
            self.last_health_check = current_time

        # 重试逻辑
        last_error = None
        retry_count = 0

        while retry_count <= ERROR_HANDLING_CONFIG["max_retries"]:
            try:
                # 分析查询复杂度（传入对话历史以更好地检测追问）
                complexity: ComplexityResult = self.complexity_analyzer.analyze(message, chat_history)

                # 决定使用哪个模型
                selected_model = self._select_model(complexity, force_model)
                use_14b = (selected_model == "14b")

                # 更新统计
                self.stats["total_count"] += 1
                if use_14b:
                    self.stats["14b_count"] += 1
                else:
                    self.stats["7b_count"] += 1

                # 更新平均复杂度
                total = self.stats["total_count"]
                self.stats["avg_complexity"] = (
                    (self.stats["avg_complexity"] * (total - 1) + complexity.score) / total
                )

                # 重置连续失败计数
                if self.stats["consecutive_failures"] > 0:
                    self.stats["consecutive_failures"] = 0

                logger.info(
                    f"🎯 模型选择: {'14B' if use_14b else '7B'} | "
                    f"复杂度={complexity.score:.2f} | "
                    f"意图={complexity.intent.value} | "
                    f"重试={retry_count}"
                )

                # 选择对应的 graph
                graph = self.master_graph_14b if use_14b else self.master_graph_7b

                # 执行超时控制
                try:
                    # 调用处理
                    result = await asyncio.wait_for(
                        graph.aprocess(
                            user_query=message,
                            session_id=session_id,
                            chat_history=chat_history,
                            config=config
                        ),
                        timeout=ERROR_HANDLING_CONFIG["timeout"]
                    )
                except asyncio.TimeoutError:
                    raise ModelError(f"模型处理超时（{ERROR_HANDLING_CONFIG['timeout']}秒）")

                # 计算处理时间
                processing_time = time.time() - start_time

                # 添加模型信息到响应
                result["model_used"] = "14b" if use_14b else "7b"
                result["model_name"] = self.model_name_14b if use_14b else self.model_name_7b
                result["complexity"] = {
                    "score": complexity.score,
                    "intent": complexity.intent.value,
                    "confidence": complexity.confidence,
                    "reasons": complexity.reasons
                }
                result["processing_time"] = round(processing_time, 2)
                result["retry_count"] = retry_count
                result["fallback_used"] = retry_count > 0

                logger.info(
                    f"✅ 响应完成: model={result['model_used']}, "
                    f"time={processing_time:.2f}s, "
                    f"retry={retry_count}"
                )

                return result

            except (ModelError, ServiceError) as e:
                last_error = e
                retry_count += 1
                self.stats["error_count"] += 1
                self.stats["consecutive_failures"] += 1

                logger.warning(f"❌ 聊天处理失败 (尝试 {retry_count}/{ERROR_HANDLING_CONFIG['max_retries']}): {e}")

                # 如果达到重试上限或失败阈值，尝试降级
                if retry_count > ERROR_HANDLING_CONFIG["max_retries"] or \
                   self.stats["consecutive_failures"] >= ERROR_HANDLING_CONFIG["fallback_threshold"]:

                    # 尝试降级到7B模型
                    logger.info("🔄 尝试降级到7B模型...")
                    try:
                        # 检查是否已经在使用7B
                        if selected_model != "7b" and self.llm_7b:
                            complexity_fallback = self.complexity_analyzer.analyze(message, chat_history)
                            fallback_selected = self._select_model(complexity_fallback, "7b")
                            use_14b_fallback = (fallback_selected == "14b")

                            if not use_14b_fallback:  # 确保使用7B
                                graph = self.master_graph_7b
                                result = await asyncio.wait_for(
                                    graph.aprocess(
                                        user_query=message,
                                        session_id=session_id,
                                        chat_history=chat_history,
                                        config=config
                                    ),
                                    timeout=ERROR_HANDLING_CONFIG["timeout"]
                                )

                                # 构建降级响应
                                processing_time = time.time() - start_time
                                result["model_used"] = "7b"
                                result["model_name"] = self.model_name_7b
                                result["complexity"] = {
                                    "score": complexity_fallback.score,
                                    "intent": complexity_fallback.intent.value,
                                    "confidence": complexity_fallback.confidence,
                                    "reasons": complexity_fallback.reasons
                                }
                                result["processing_time"] = round(processing_time, 2)
                                result["retry_count"] = retry_count
                                result["fallback_used"] = True
                                result["fallback_reason"] = str(last_error)

                                self.stats["fallback_count"] += 1
                                self.stats["consecutive_failures"] = 0  # 重置失败计数

                                logger.info(f"✅ 降级成功: model={result['model_used']}")
                                return result

                    except Exception as fallback_error:
                        logger.error(f"❌ 降级也失败: {fallback_error}")
                        continue

            except Exception as e:
                last_error = e
                self.stats["error_count"] += 1
                self.stats["consecutive_failures"] += 1
                logger.error(f"❌ 未预期的错误: {e}")

                # 记录错误历史
                self.error_history.append({
                    "timestamp": time.time(),
                    "error": str(e),
                    "model_selected": selected_model,
                    "retry_count": retry_count
                })

                # 清理旧错误记录（保留最近100条）
                if len(self.error_history) > 100:
                    self.error_history = self.error_history[-100:]

        # 所有重试都失败了
        logger.error(f"❌ 所有尝试都失败: {last_error}")
        return {
            "success": False,
            "error": str(last_error) if last_error else "未知错误",
            "answer": "抱歉，服务暂时不可用，请稍后再试。",
            "model_stats": {
                "error_type": "service_failure",
                "fallback_used": False,
                "retry_attempts": retry_count,
                "consecutive_failures": self.stats["consecutive_failures"]
            }
        }

    def chat(
        self,
        message: str,
        session_id: Optional[str] = None,
        chat_history: Optional[List[Dict[str, str]]] = None,
        config: Optional[Dict[str, Any]] = None,
        force_model: Optional[str] = None
    ) -> Dict[str, Any]:
        """
        同步聊天

        Args:
            message: 用户消息
            session_id: 会话ID
            chat_history: 对话历史
            config: 额外配置
            force_model: 强制指定模型 ("7b" 或 "14b")

        Returns:
            响应字典
        """
        if not self._initialized:
            return {
                "success": False,
                "error": "DualModelChatService 未初始化",
                "answer": "抱歉，服务尚未初始化。",
                "model_stats": {
                    "error_type": "service_uninitialized",
                    "fallback_used": True
                }
            }

        start_time = time.time()
        last_error = None
        retry_count = 0

        while retry_count <= ERROR_HANDLING_CONFIG["max_retries"]:
            try:
                # 分析查询复杂度
                complexity: ComplexityResult = self.complexity_analyzer.analyze(message, chat_history)

                # 决定使用哪个模型
                selected_model = self._select_model(complexity, force_model)
                use_14b = (selected_model == "14b")

                # 更新统计
                self.stats["total_count"] += 1
                if use_14b:
                    self.stats["14b_count"] += 1
                else:
                    self.stats["7b_count"] += 1

                # 更新平均复杂度
                total = self.stats["total_count"]
                self.stats["avg_complexity"] = (
                    (self.stats["avg_complexity"] * (total - 1) + complexity.score) / total
                )

                # 重置连续失败计数
                if self.stats["consecutive_failures"] > 0:
                    self.stats["consecutive_failures"] = 0

                logger.info(
                    f"🎯 模型选择: {'14B' if use_14b else '7B'} | "
                    f"复杂度={complexity.score:.2f} | "
                    f"意图={complexity.intent.value} | "
                    f"重试={retry_count}"
                )

                # 选择对应的 graph
                graph = self.master_graph_14b if use_14b else self.master_graph_7b

                # 执行超时控制
                try:
                    result = graph.process(
                        user_query=message,
                        session_id=session_id,
                        chat_history=chat_history,
                        config=config
                    )
                except Exception as e:
                    raise ModelError(f"模型处理失败: {e}")

                # 计算处理时间
                processing_time = time.time() - start_time

                # 添加模型信息到响应
                result["model_used"] = "14b" if use_14b else "7b"
                result["model_name"] = self.model_name_14b if use_14b else self.model_name_7b
                result["complexity"] = {
                    "score": complexity.score,
                    "intent": complexity.intent.value,
                    "confidence": complexity.confidence,
                    "reasons": complexity.reasons
                }
                result["processing_time"] = round(processing_time, 2)
                result["retry_count"] = retry_count
                result["fallback_used"] = retry_count > 0

                logger.info(
                    f"✅ 响应完成: model={result['model_used']}, "
                    f"time={processing_time:.2f}s, "
                    f"retry={retry_count}"
                )

                return result

            except (ModelError, ServiceError) as e:
                last_error = e
                retry_count += 1
                self.stats["error_count"] += 1
                self.stats["consecutive_failures"] += 1

                logger.warning(f"❌ 聊天处理失败 (尝试 {retry_count}/{ERROR_HANDLING_CONFIG['max_retries']}): {e}")

                # 检查是否需要降级
                if retry_count > ERROR_HANDLING_CONFIG["max_retries"] or \
                   self.stats["consecutive_failures"] >= ERROR_HANDLING_CONFIG["fallback_threshold"]:

                    logger.info("🔄 尝试降级到7B模型...")
                    try:
                        # 尝试使用7B模型
                        complexity_fallback = self.complexity_analyzer.analyze(message, chat_history)
                        fallback_selected = self._select_model(complexity_fallback, "7b")
                        use_14b_fallback = (fallback_selected == "14b")

                        if not use_14b_fallback and self.master_graph_7b:
                            result = self.master_graph_7b.process(
                                user_query=message,
                                session_id=session_id,
                                chat_history=chat_history,
                                config=config
                            )

                            processing_time = time.time() - start_time
                            result["model_used"] = "7b"
                            result["model_name"] = self.model_name_7b
                            result["complexity"] = {
                                "score": complexity_fallback.score,
                                "intent": complexity_fallback.intent.value,
                                "confidence": complexity_fallback.confidence,
                                "reasons": complexity_fallback.reasons
                            }
                            result["processing_time"] = round(processing_time, 2)
                            result["retry_count"] = retry_count
                            result["fallback_used"] = True
                            result["fallback_reason"] = str(last_error)

                            self.stats["fallback_count"] += 1
                            self.stats["consecutive_failures"] = 0

                            logger.info(f"✅ 降级成功: model={result['model_used']}")
                            return result

                    except Exception as fallback_error:
                        logger.error(f"❌ 降级也失败: {fallback_error}")
                        continue

            except Exception as e:
                last_error = e
                self.stats["error_count"] += 1
                self.stats["consecutive_failures"] += 1
                logger.error(f"❌ 未预期的错误: {e}")

                # 记录错误历史
                self.error_history.append({
                    "timestamp": time.time(),
                    "error": str(e),
                    "model_selected": selected_model,
                    "retry_count": retry_count
                })

                # 清理旧错误记录
                if len(self.error_history) > 100:
                    self.error_history = self.error_history[-100:]

        # 所有重试都失败了
        logger.error(f"❌ 所有尝试都失败: {last_error}")
        return {
            "success": False,
            "error": str(last_error) if last_error else "未知错误",
            "answer": "抱歉，服务暂时不可用，请稍后再试。",
            "model_stats": {
                "error_type": "service_failure",
                "fallback_used": False,
                "retry_attempts": retry_count,
                "consecutive_failures": self.stats["consecutive_failures"]
            }
        }

    def _select_model(
        self,
        complexity: ComplexityResult,
        force_model: Optional[str] = None
    ) -> str:
        """
        选择使用的模型

        Args:
            complexity: 复杂度分析结果
            force_model: 强制指定的模型

        Returns:
            "7b" 或 "14b"
        """
        # 如果强制指定，使用指定的模型
        if force_model:
            if force_model.lower() in ["7b", "14b"]:
                # 检查 14B 是否可用
                if force_model.lower() == "14b" and self.llm_14b is None:
                    logger.warning("⚠️ 请求使用 14B 但模型不可用，降级到 7B")
                    return "7b"
                return force_model.lower()

        # 如果 14B 不可用，使用 7B
        if self.llm_14b is None:
            return "7b"

        # 根据复杂度选择
        if complexity.use_large_model:
            return "14b"
        return "7b"

    async def _perform_health_check(self):
        """执行内部健康检查"""
        try:
            # 检查7B模型可用性
            if self.llm_7b:
                try:
                    # 发送简单的测试消息
                    test_response = await asyncio.wait_for(
                        self.llm_7b.ainvoke("测试"),
                        timeout=10
                    )
                    logger.debug("✅ 7B模型健康检查通过")
                except Exception as e:
                    logger.warning(f"❌ 7B模型健康检查失败: {e}")
                    self.llm_7b = None

            # 检查14B模型可用性
            if self.llm_14b:
                try:
                    test_response = await asyncio.wait_for(
                        self.llm_14b.ainvoke("测试"),
                        timeout=15
                    )
                    logger.debug("✅ 14B模型健康检查通过")
                except Exception as e:
                    logger.warning(f"❌ 14B模型健康检查失败: {e}")
                    self.llm_14b = None

            # 检查Graph可用性
            if self.master_graph_7b:
                try:
                    # 这里可以添加更详细的检查
                    pass
                except Exception as e:
                    logger.warning(f"❌ 7B Graph健康检查失败: {e}")

            if self.master_graph_14b:
                try:
                    pass
                except Exception as e:
                    logger.warning(f"❌ 14B Graph健康检查失败: {e}")

        except Exception as e:
            logger.error(f"❌ 健康检查过程出错: {e}")

    def health_check(self) -> Dict[str, Any]:
        """
        健康检查

        Returns:
            组件状态和错误统计
        """
        status = {
            "initialized": self._initialized,
            "components": {},
            "error_tracking": {
                "total_errors": self.stats["error_count"],
                "fallback_count": self.stats["fallback_count"],
                "consecutive_failures": self.stats["consecutive_failures"],
                "last_health_check": self.last_health_check
            }
        }

        if self._initialized:
            # 检查组件状态
            status["components"]["llm_7b"] = {
                "status": "healthy" if self.llm_7b else "not_configured",
                "model": self.model_name_7b,
                "available": bool(self.llm_7b)
            }

            status["components"]["llm_14b"] = {
                "status": "healthy" if self.llm_14b else "not_configured",
                "model": self.model_name_14b,
                "available": bool(self.llm_14b)
            }

            status["components"]["master_graph_7b"] = {
                "status": "healthy" if self.master_graph_7b else "not_configured",
                "available": bool(self.master_graph_7b)
            }

            status["components"]["master_graph_14b"] = {
                "status": "healthy" if self.master_graph_14b else "not_configured",
                "available": bool(self.master_graph_14b)
            }

            status["components"]["complexity_analyzer"] = {
                "status": "healthy",
                "threshold": self.threshold
            }

            # 统计信息
            status["statistics"] = self.stats

            # 错误率计算
            if self.stats["total_count"] > 0:
                status["error_tracking"]["error_rate"] = round(
                    self.stats["error_count"] / self.stats["total_count"] * 100, 2
                )
                status["error_tracking"]["fallback_rate"] = round(
                    self.stats["fallback_count"] / self.stats["total_count"] * 100, 2
                )

            # 系统建议
            status["recommendations"] = []

            if self.stats["consecutive_failures"] >= ERROR_HANDLING_CONFIG["fallback_threshold"]:
                status["recommendations"].append("系统检测到连续失败，建议重启服务")

            # 使用计算出的 error_rate 而不是从 self.stats 访问
            error_rate = status["error_tracking"].get("error_rate", 0)
            if error_rate > 20:
                status["recommendations"].append("错误率较高，建议检查模型状态")

            if not self.llm_14b and self.stats["total_count"] > 10:
                status["recommendations"].append("14B模型未启用，复杂查询将使用7B模型")

        return status

    def get_statistics(self) -> Dict[str, Any]:
        """
        获取使用统计

        Returns:
            统计信息，包含详细的错误和恢复统计
        """
        stats = {
            "basic_stats": {
                "7b_count": self.stats["7b_count"],
                "14b_count": self.stats["14b_count"],
                "total_count": self.stats["total_count"],
                "avg_complexity": round(self.stats["avg_complexity"], 3),
                "14b_ratio": round(
                    self.stats["14b_count"] / max(self.stats["total_count"], 1) * 100, 1
                ) if self.stats["total_count"] > 0 else 0
            },
            "error_stats": {
                "total_errors": self.stats["error_count"],
                "fallback_count": self.stats["fallback_count"],
                "consecutive_failures": self.stats["consecutive_failures"],
                "error_rate": round(
                    self.stats["error_count"] / max(self.stats["total_count"], 1) * 100, 2
                ) if self.stats["total_count"] > 0 else 0,
                "fallback_rate": round(
                    self.stats["fallback_count"] / max(self.stats["total_count"], 1) * 100, 2
                ) if self.stats["total_count"] > 0 else 0
            },
            "model_availability": {
                "7b_available": bool(self.llm_7b),
                "14b_available": bool(self.llm_14b),
                "auto_fallback_enabled": True
            },
            "performance": {
                "avg_processing_time": self._get_avg_processing_time(),
                "last_error_time": self._get_last_error_time(),
                "recovery_success_rate": self._calculate_recovery_rate()
            }
        }

        return stats

    def get_error_history(self, limit: int = 10) -> List[Dict[str, Any]]:
        """
        获取最近的错误历史

        Args:
            limit: 返回的记录数量

        Returns:
            错误历史记录列表
        """
        return self.error_history[-limit:] if self.error_history else []

    def _get_avg_processing_time(self) -> float:
        """估算平均处理时间"""
        # 这里可以从日志中估算，或者返回一个默认值
        return 2.5  # 默认2.5秒

    def _get_last_error_time(self) -> Optional[float]:
        """获取最后一次错误的时间"""
        if self.error_history:
            return self.error_history[-1]["timestamp"]
        return None

    def _calculate_recovery_rate(self) -> float:
        """计算恢复成功率"""
        if self.stats["fallback_count"] == 0:
            return 100.0

        successful_fallbacks = 0
        for error in self.error_history:
            if error.get("recovery_success", False):
                successful_fallbacks += 1

        return round(successful_fallbacks / max(self.stats["fallback_count"], 1) * 100, 1)

    def reset_error_tracking(self):
        """重置错误跟踪"""
        self.error_history = []
        self.stats["error_count"] = 0
        self.stats["fallback_count"] = 0
        self.stats["consecutive_failures"] = 0
        logger.info("✅ 错误跟踪已重置")


# 全局单例
_dual_model_service: Optional[DualModelChatService] = None


def get_dual_model_service() -> DualModelChatService:
    """
    获取双模型服务实例（单例模式）

    Returns:
        DualModelChatService 实例
    """
    global _dual_model_service
    if _dual_model_service is None:
        _dual_model_service = DualModelChatService()
    return _dual_model_service


def set_dual_model_service(service: DualModelChatService):
    """
    设置双模型服务实例

    Args:
        service: DualModelChatService 实例
    """
    global _dual_model_service
    _dual_model_service = service
