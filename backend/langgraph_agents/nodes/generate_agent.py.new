"""
GenerateAgent - 答案生成智能体

负责基于检索结果和分析结果生成最终答案
"""

import logging
from typing import Dict, Any, List
from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage
from ..state import AgentState

logger = logging.getLogger(__name__)


class GenerateAgent:
    """
    答案生成Agent

    功能：
    1. 基于检索结果和分析结果生成最终答案
    2. 使用LLM进行推理和生成
    3. 计算置信度

    设计理念：
    - 确定的答案格式
    - 基于上下文生成回答
    - 准确的置信度评估
    """

    KNOWLEDGE_BASE_KEYWORDS = [
        "知识库", "文档", "文件", "上传", "入库", "分块", "检索",
        "多少个", "有哪些", "列表", "状态", "清单"
    ]

    def __init__(self, llm: ChatOllama = None):
        """
        初始化GenerateAgent

        Args:
            llm: LLM实例
        """
        self.llm = llm
        self.system_prompt = self._build_system_prompt()

    def _build_system_prompt(self) -> str:
        """构建系统提示词"""
        return """你是DeepDoc系统的答案生成专家。你的任务是基于检索到的文档生成清晰、准确的答案。

## 答案格式要求：

你的答案必须严格按照以下格式输出：

```
【直接回答】
[明确的答案内容]
```

【详细说明】
[必要的解释和说明]
```

【数据来源】
12月放号独立部分-酬金.xlsx
12月放号独立部分（政策-操作-ID）.xlsx
```

## 重要约束：

1. **不要添加"建议"部分** - 禁止生成任何建议内容
2. **数据来源必须使用上下文中提供的文档名称** - 在"## 数据来源文档名称"部分会明确告诉你应该使用哪些文档名称，请直接复制使用，不要修改
3. **只列出实际引用的文档** - 答案中引用了哪个文档就列出哪个
4. **不要编造文档名** - 只使用检索到的文档名称
5. **使用纯文本格式** - 不要使用LaTeX数学公式格式（如 \[...\] 或 \(\)），直接用文字描述计算过程，如"89元 × 15% = 13.35元"
6. **先确定匹配的业务场景，再查找对应的计算规则**

当涉及渠道政策、酬金、补贴等业务问题时，必须：
    1. **仔细识别问题中的关键条件**：
       - 渠道类型：非区域服务商/区域服务商/委托/代办厅/宽带业务/微格渠道/终端渠道/厂家渠道
       - 星级：1星-6星（星级服务补与渠道类型服务补不同）
       - 套餐类型和价格
       - 时间周期（T3-T12等）

    2. **不要混淆不同渠道的补贴标准**：
       - "委托"、"代办厅"、"宽带业务"、"微格渠道"、"终端渠道"、"厂家渠道"的35元/户标准 ≠ 星级服务补
       - 星级服务补计算公式：折后价 × 15%

    3. **首先确定匹配的业务场景，再查找对应的计算规则**

请严格按照此格式回答，不要添加其他部分。
"""

    async def __call__(self, state: AgentState) -> AgentState:
        """
        生成答案

        Args:
            state: 当前状态

        Returns:
            更新后的状态
        """
        query = state["user_query"]
        intent = state["intent"]
        docs = state["retrieved_docs"]
        analysis = state.get("analysis_results", {})
        reasoning_steps = state.get("reasoning_steps", [])

        logger.info(f"GenerateAgent: 生成答案 - intent={intent}")

        try:
            # 检查是否是知识库状态查询
            is_knowledge_base_query = self._is_knowledge_base_query(query)

            # 识别业务场景（用于服务补、酬金类问题）
            business_scenario = self._identify_business_scenario(query)

            # 构建上下文
            context = self._build_context(docs, analysis, reasoning_steps, is_knowledge_base_query, business_scenario)

            # 使用LLM生成答案
            answer = await self._generate_answer(query, context, intent)
            state["draft_answer"] = answer
            state["final_answer"] = answer

            # 计算置信度
            confidence = self._calculate_confidence(state)
            state["confidence"] = confidence

            # 递增迭代计数器（regenerate循环）
            state["current_iteration"] = state.get("current_iteration", 0) + 1

            logger.info(f"GenerateAgent: 答案生成完成, 置信度={confidence:.2f}")

            return state

        except Exception as e:
            logger.error(f"GenerateAgent错误: {e}")
            # 降级：返回简单的答案
            state["draft_answer"] = self._generate_simple_answer(docs, analysis)
            state["final_answer"] = state["draft_answer"]
            state["confidence"] = 0.5

            return state

    def _is_knowledge_base_query(self, query: str) -> bool:
        """检查是否是知识库状态查询"""
        query_lower = query.lower()
        return any(keyword in query for keyword in self.KNOWLEDGE_BASE_KEYWORDS)

    def _identify_business_scenario(self, query: str) -> dict:
        """
        识别业务场景

        返回：
        - is_service_subsidy: 是否为服务补问题
        - is_commission: 是否为酬金问题
        - channel_type: 渠道类型
        - star_level: 星级
        - key_terms: 关键词列表
        """
        scenario = {
            "is_service_subsidy": False,
            "is_commission": False,
            "channel_type": None,
            "star_level": None,
            "key_terms": []
        }

        # 识别关键词
        service_subsidy_keywords = ["服务补", "服务运营补贴", "补贴"]
        commission_keywords = ["酬金", "提成", "分成"]
        channel_35_keywords = {
            "代办厅": "代办厅",
            "宽带业务": "宽带业务",
            "微格渠道": "微格渠道",
            "终端渠道": "终端渠道",
            "厂家渠道": "厂家渠道"
        }
        star_level_keywords = ["1星", "2星", "3星", "4星", "5星", "6星", "星A", "星B", "星C"]

        # 检查是否为服务补问题
        if any(keyword in query for keyword in service_subsidy_keywords):
            scenario["is_service_subsidy"] = True
            scenario["key_terms"].append("服务补问题")

        # 检查是否为酬金问题
        if any(keyword in query for keyword in commission_keywords):
            scenario["is_commission"] = True
            scenario["key_terms"].append("酬金问题")

        # 识别35元/户的特定渠道类型（先检查星级渠道）
        is_35yuan_channel = False
        for star, channel_type in channel_35_keywords.items():
            if star in query:
                scenario["channel_type"] = channel_type
                scenario["key_terms"].append(f"渠道类型:{channel_type}(35元/户标准)")
                is_35yuan_channel = True
                break

        # 如果是35元/户渠道，不要标记为星级服务补
        if is_35yuan_channel:
            scenario["is_service_subsidy"] = False

        # 识别星级
        for star in star_level_keywords:
            if star in query:
                scenario["star_level"] = star
                scenario["key_terms"].append(f"星级:{star}")
                break

        # 识别渠道类型（先检查35元/户的特定渠道）
        # 区域服务商类型（可能与星级服务补相关）
        regional_keywords = {
            "非区域服务商": "非区域服务商",
            "区域服务商": "区域服务商"
        }
        for keyword, channel_type in regional_keywords.items():
            if keyword in query:
                scenario["regional_type"] = channel_type
                scenario["key_terms"].append(f"区域类型:{channel_type}")
                break

        return scenario

    def _build_context(
        self,
        docs: List[Dict],
        analysis: Dict,
        reasoning_steps: List[str],
        is_knowledge_base_query: bool,
        business_scenario: Dict
    ) -> str:
        """构建上下文"""
        context_parts = []

        # 添加检索到的文档信息
        if docs:
            context_parts.append("检索到相关文档：")
            for doc_name in sorted(set(doc["filename"] for doc in docs]):
                context_parts.append(f"- {doc_name}")
            context_parts.append(f"共检索到 {len(docs)} 个文档")

        # 添加分析结果
        if analysis:
            context_parts.append("\n分析结果：")
            if analysis.get("type"):
                context_parts.append(f"分析类型: {analysis['type']}")
            if analysis.get("key_points"):
                context_parts.append("关键点:")
                for point in analysis["key_points"]:
                    context_parts.append(f"  - {point}")

        # 添加业务场景（用于服务补、酬金类问题）
        if business_scenario.get("is_service_subsidy") or business_scenario.get("is_commission"):
            context_parts.append(f"\n业务场景: {business_scenario.get('channel_type', '其他')}")

        # 添加推理步骤（如果有）
        if reasoning_steps:
            context_parts.append("\n推理步骤：")
            for step in reasoning_steps:
                context_parts.append(f"{step}")

        # 添加数据来源文档名称列表（重要！）
        if docs:
            actual_doc_names = sorted(set(doc["filename"] for doc in docs))
            context_parts.append("\n## 数据来源文档名称\n")
            for doc_name in actual_doc_names:
                context_parts.append(f"- {doc_name}")

        return "\n".join(context_parts)

    async def _generate_answer(
        self,
        query: str,
        context: str,
        intent: str
    ) -> str:
        """使用LLM生成答案"""
        messages = [
            SystemMessage(content=self.system_prompt),
            HumanMessage(content=f"请根据以下上下文回答用户问题：\n\n查询：{query}\n\n上下文：\n{context}\n\n请严格按照答案格式要求输出。")
        ]

        # 尝试多次连接（增强稳定性）
        max_retries = 3
        retry_delay = 1  # 秒

        for attempt in range(max_retries):
            try:
                logger.info(f"GenerateAgent: 尝试LLM连接 (第{attempt + 1}次)...")
                response = await self.llm.ainvoke(messages, timeout=30)
                answer = response.content.strip()

                # 确保答案不为空
                if not answer:
                    answer = "抱歉，我无法基于提供的上下文生成答案。"

                logger.info(f"GenerateAgent: LLM响应: {answer[:200]}")

                # 成功：返回答案
                state["draft_answer"] = answer
                state["final_answer"] = answer
                state["confidence"] = self._calculate_confidence(state)
                return state

            except Exception as e:
                logger.warning(f"GenerateAgent: 第{attempt + 1}次尝试失败: {str(e)[:100]}")

                # 最后一次尝试：使用降级答案
                if attempt == max_retries - 1:
                    logger.warning("GenerateAgent: 所有尝试失败，使用降级答案")
                    state["draft_answer"] = self._generate_simple_answer(docs, analysis)
                    state["final_answer"] = state["draft_answer"]
                    state["confidence"] = 0.5
                else:
                    # 等待后重试
                    import asyncio
                    await asyncio.sleep(retry_delay)
                    continue

        # 如果所有重试都失败
        if "final_answer" not in state:
            logger.warning("GenerateAgent: 未能生成答案，返回降级响应")
            state["draft_answer"] = self._generate_simple_answer(docs, analysis)
            state["final_answer"] = state["draft_answer"]
            state["confidence"] = 0.5

        return state

    def _generate_simple_answer(self, docs: List[Dict], analysis: Dict) -> str:
        """生成简单答案（降级用）"""
        if not docs:
            return "抱歉，我无法基于提供的上下文生成答案。请确保文档已正确上传并处理完成。"

        doc_names = [doc["filename"] for doc in docs]
        doc_list = "、".join(doc_names[:3])
        if len(doc_names) > 3:
            doc_list += f"等{len(doc_names) - 3}个文档"

        answer_parts = [f"根据知识库中的文档：{doc_list}"]
        if analysis:
            if analysis.get("type"):
                answer_parts.append(f"分析类型: {analysis['type']}")
            if analysis.get("key_points"):
                answer_parts.append("关键点:")
                for point in analysis["key_points"]:
                    answer_parts.append(f"  - {point}")

        return "\n".join(answer_parts)

    def _calculate_confidence(self, state: AgentState) -> float:
        """计算置信度"""
        # 基于检索质量和答案完整性计算置信度
        retrieval_quality = state.get("retrieval_quality", 0.5)
        has_answer = bool(state.get("draft_answer", ""))
        has_sources = bool(state.get("sources", []))

        # 基础分
        base_score = retrieval_quality * 0.4

        # 答案完整性加分
        if has_answer:
            base_score += 0.3
        if has_sources and len(state.get("sources", [])) > 0:
            base_score += 0.3

        return min(base_score, 1.0)
