class GenerateAgent:
    """
    答案生成Agent

    功能：
    1. 基于检索结果生成最终答案
    2. 使用LLM进行推理和生成
    3. 计算置信度

    设计理念：
    - 标准化的答案格式
    - 基于文档内容生成回答
    - 准确的置信度评估
    - 无硬编码业务规则
    """

    KNOWLEDGE_BASE_KEYWORDS = [
        "知识库", "文档", "文件", "上传", "入库", "分块", "检索",
        "多少个", "有哪些", "列表", "状态", "清单"
    ]

    def __init__(self, llm: ChatOllama = None):
        """
        初始化GenerateAgent

        Args:
            llm: LLM实例
        """
        self.llm = llm
        self.system_prompt = self._build_system_prompt()
        self._prompt_cache = {}  # 添加提示词缓存

        # 初始化枚举增强器
        self.enumeration_enhancer = None
        if USE_ENUMERATION_ENHANCER:
            self.enumeration_enhancer = get_enumeration_enhancer()

        # 初始化对话上下文增强器
        self.context_enhancer = None
        if USE_CONTEXT_ENHANCER:
            self.context_enhancer = get_context_enhancer()

        # 初始化关键数值完整性检查器
        self.critical_checker = None
        if USE_CRITICAL_CHECKER:
            self.critical_checker = get_completeness_checker()

        # 初始化Phase 1优化模块
        self.constraint_extractor = None
        if USE_CONSTRAINT_EXTRACTOR:
            self.constraint_extractor = get_constraint_extractor()

        # 方案3: 初始化条件提取器
        self.condition_extractor = None
        if USE_CONDITION_EXTRACTOR:
            print(f"[DEBUG] 方案3: USE_CONDITION_EXTRACTOR={USE_CONDITION_EXTRACTOR}, 正在初始化ConditionExtractor...")
            self.condition_extractor = ConditionExtractor()
            print(f"[DEBUG] 方案3: ConditionExtractor初始化完成, extractor={self.condition_extractor is not None}")
        else:
            print(f"[DEBUG] 方案3: USE_CONDITION_EXTRACTOR={USE_CONDITION_EXTRACTOR}, 跳过初始化")

        self.table_parser = None
        if USE_TABLE_PARSER:
            self.table_parser = get_table_parser()

        # Phase 2 配置缓存 (必须在answer_validator之前初始化)
        self._phase2_config = None

        self.answer_validator = None
        if USE_ANSWER_VALIDATOR:
            # Phase 2: 加载增强配置
            validator_config = self._load_phase2_config()
            self.answer_validator = get_answer_validator(validator_config)

        self.config_loader = None
        if USE_CONFIG_LOADER:
            self.config_loader = get_config_loader()

    def _load_phase2_config(self) -> Dict[str, Any]:
        """加载 Phase 2 配置"""
        if self._phase2_config is not None:
            return self._phase2_config

        config = {
            'max_direct_answer_length': 50,
            'min_detailed_explanation_length': 30,
            'score_threshold': 60,
            # Phase 2 新增配置
            'max_repetition_ratio': 0.3,
            'list_completeness_check': True,
            'time_period_check': True,
        }

        if USE_PHASE2_CONFIG and PHASE2_CONFIG_PATH:
            try:
                import yaml
                with open(PHASE2_CONFIG_PATH, 'r', encoding='utf-8') as f:
                    yaml_config = yaml.safe_load(f)

                    # 加载 Phase 2 验证配置
                    if 'phase2_validation' in yaml_config:
                        phase2_config = yaml_config['phase2_validation']
                        config.update({
                            'max_repetition_ratio': phase2_config.get('repetition_check', {}).get('max_repetition_ratio', 0.3),
                            'list_completeness_check': phase2_config.get('list_completeness_check', {}).get('enabled', True),
                            'time_period_check': phase2_config.get('time_period_check', {}).get('enabled', True),
                        })

                    # 加载格式配置
                    if 'answer_format' in yaml_config:
                        answer_format = yaml_config['answer_format']
                        config['max_direct_answer_length'] = answer_format.get('max_direct_answer_length', 50)
                        config['min_detailed_explanation_length'] = answer_format.get('min_detailed_explanation_length', 30)

                    # 加载验证阈值
                    if 'validation_thresholds' in yaml_config:
                        config['score_threshold'] = yaml_config['validation_thresholds'].get('min_acceptable_score', 60)

                    logger.info(f"✅ [Phase 2] 配置已加载: max_repetition_ratio={config['max_repetition_ratio']}")
            except Exception as e:
                logger.warning(f"⚠️ [Phase 2] 配置加载失败: {e}")

        self._phase2_config = config
        return config

    def _build_system_prompt(self, use_optimized: bool = None) -> str:
        """
        构建系统提示词（优化版或默认版）

        Args:
            use_optimized: 是否使用优化提示词，None时自动检测
        """
        # 自动检测是否使用优化提示词
        if use_optimized is None:
            use_optimized = USE_OPTIMIZED_PROMPTS

        if use_optimized and OptimizedPromptService:
            # 使用优化的提示词服务
            core_prompt = OptimizedPromptService.CORE_PROMPT

            # 添加必需的格式要求
            format_requirements = """
## 答案格式要求（必须严格遵守）：

你的答案必须严格按照以下格式输出：

【直接回答】
[全面且简洁的答案，包含所有关键信息，用•列出要点]

【数据来源】
• [具体的文档名称]

## ⚠️ 格式要求细节：

1. **【直接回答】后必须换行** - 不要紧跟内容或句号
   - ✅ 正确：【直接回答】
5元/账户，包含...（具体说明）
   - ❌ 错误：【直接回答】。5元/账户

2. **【数据来源】后必须换行** - 不要紧跟内容或句号
   - ✅ 正确：【数据来源】
• 12月渠道政策（一）.docx
   - ❌ 错误：【数据来源】。文档名称

3. **各部分之间用空行分隔**

## ⚠️ 重要警告：
- 禁止使用"问题：...答案：..."格式
- 禁止使用markdown代码块
- 所有信息必须来自检索到的文档
- 答案要全面但简洁，一次回答包含所有必要信息

## 数据准确性原则：
1. 逐字逐句提取 - 数值、比例、金额必须准确
2. 精确计算 - 给出公式和结果（如：89元 × 15% = 13.35元）
3. 表格数据优先 - 表格比文本更准确
4. 对比类问题 - 必须为每个类别分别说明

## 表格对比数据格式：
- 转置表格：第一列是指标，后续列是不同类别的数值
- 对比格式：指标: 类别1=值1 | 类别2=值2
- 对比问题必须列出所有类别的完整数据"""

            return core_prompt + format_requirements
        else:
            # 使用简化两段式答案格式
            return """基于文档内容回答用户问题。

【输出格式】

【直接回答】
[全面且简洁的答案，包含所有关键信息，用•列出要点]

【数据来源】
• [具体的文档名称]

【要求】
- 数据准确来自文档
- 不要使用markdown格式
- 列表使用•符号
- 答案要全面但简洁，包含所有必要信息
"""

    async def __call__(self, state: AgentState) -> AgentState:
        """
        生成答案

        Args:
            state: 当前状态

        Returns:
            更新后的状态
        """
        # 使用 rewritten_query（包含上下文信息）
        query = state.get("rewritten_query", state["user_query"])
        original_query = state["user_query"]
        intent = state["intent"]
        docs = state["retrieved_docs"]
        analysis = state.get("analysis_results", {})
        reasoning_steps = state.get("reasoning_steps", [])
        chat_history = state.get("chat_history", [])

        logger.info(f"GenerateAgent: 生成答案 - intent={intent}, query={query}")

        # 检查是否是知识库状态查询
        is_knowledge_base_query = self._is_knowledge_base_query(query)

        # 检测是否为枚举类问题
        is_enumeration = False
        if self.enumeration_enhancer:
            is_enumeration = self.enumeration_enhancer.is_enumeration_question(original_query)
            if is_enumeration:
                logger.info(f"检测到枚举类问题: {original_query[:50]}...")

        # 检测是否为追问
        is_followup = False
        if self.context_enhancer and chat_history:
            is_followup = self.context_enhancer.is_followup_question(original_query)
            if is_followup:
                logger.info(f"检测到追问: {original_query[:50]}...")

        try:
            # 构建上下文（传入查询信息用于枚举检测和追问增强）
            context = self._build_context(
                docs, analysis, reasoning_steps, is_knowledge_base_query,
                original_query=original_query,
                is_followup=is_followup,
                chat_history=chat_history
            )

            # 使用LLM生成答案
            answer = await self._generate_answer(
                original_query=original_query,
                rewritten_query=query,
                context=context,
                intent=intent,
                chat_history=chat_history,
                is_enumeration=is_enumeration,
                is_followup=is_followup,
                docs=docs  # Phase 2: 传递docs用于验证
            )

            logger.info(f"GenerateAgent: 答案生成完成，长度={len(answer)} 字符")

            # 🔧 使用后处理器清理答案格式
            logger.info(f"GenerateAgent: 准备调用后处理器清理格式...")
            from services.post_processor import AnswerPostProcessor
            post_processor = AnswerPostProcessor()
            answer = post_processor.process(answer)
            logger.info(f"GenerateAgent: 后处理完成，长度={len(answer)} 字符")

            # 🔧 修复答案格式（处理句号和换行问题）
            logger.info(f"GenerateAgent: 准备调用格式修复器...")
            answer = self._fix_answer_format(answer)
            logger.info(f"GenerateAgent: 格式修复完成，长度={len(answer)} 字符")

            state["draft_answer"] = answer
            state["final_answer"] = answer

            # 计算置信度
            confidence = self._calculate_confidence(state)
            state["confidence"] = confidence

            logger.info(f"GenerateAgent: 答案生成完成, 置信度={confidence:.2f}")

            return state

        except Exception as e:
            logger.error(f"GenerateAgent错误: {e}")
            import traceback
            logger.error(traceback.format_exc())
            # 降级：返回简单的答案
            simple_answer = self._generate_simple_answer(docs, analysis)
            # 🔧 修复答案格式（处理句号和换行问题）
            simple_answer = self._fix_answer_format(simple_answer)
            state["draft_answer"] = simple_answer
            state["final_answer"] = simple_answer
            state["confidence"] = 0.5

            return state

    def _is_knowledge_base_query(self, query: str) -> bool:
        """检查是否是知识库状态查询"""
        query_lower = query.lower()
        return any(keyword in query for keyword in self.KNOWLEDGE_BASE_KEYWORDS)

    def _remove_thinking_process(self, answer: str) -> str:
        """
        移除 DeepSeek-R1 的思考过程输出

        DeepSeek-R1 会输出类似这样的内容：
        "首先，查看文档内容...
        ...done thinking.
        【直接回答】..."

        我们只需要保留【直接回答】之后的内容。

        Args:
            answer: 原始答案

        Returns:
            移除思考过程后的答案
        """
        import re

        # 方法1: 查找【直接回答】标记，保留从此开始的内容
        direct_answer_marker = "【直接回答】"
        if direct_answer_marker in answer:
            # 找到【直接回答】的位置
            idx = answer.find(direct_answer_marker)
            return answer[idx:]

        # 方法2: 查找 "...done thinking." 或 "...done thinking" 标记
        thinking_end_patterns = [
            r'\.\.\.done thinking\.',
            r'\.\.\.done thinking',
            r'…done thinking\.',
            r'done thinking',
        ]

        for pattern in thinking_end_patterns:
            if pattern in answer.lower():
                # 分割并取后半部分
                parts = re.split(pattern, answer, flags=re.IGNORECASE)
                if len(parts) > 1:
                    result = parts[-1].strip()
                    # 如果结果不为空且不是以【开头，可能需要处理
                    if result and not result.startswith('【'):
                        # 尝试查找第一个【标记
                        bracket_idx = result.find('【')
                        if bracket_idx > 0:
                            result = result[bracket_idx:]
                    return result if result else answer

        # 方法3: 如果答案很长且包含中文思考词汇，尝试移除前面的部分
        thinking_indicators = [
            '首先，',
            '接下来，',
            '然后，',
            '最后，',
            '首先查看',
            '接下来检查',
            '综合以上',
        ]

        lines = answer.split('\n')
        result_lines = []
        skip_thinking = True

        for line in lines:
            if skip_thinking:
                # 如果这一行包含【直接回答】或类似标记，停止跳过
                if '【' in line and '】' in line:
                    skip_thinking = False
                    result_lines.append(line)
                # 如果这一行很短且看起来像思考内容，继续跳过
                elif any(indicator in line for indicator in thinking_indicators):
                    continue
                # 如果已经积累了很多行思考内容，保持跳过
                elif len(result_lines) == 0 and len(line) > 50:
                    # 这可能是连续的思考内容
                    continue
                else:
                    skip_thinking = False
                    result_lines.append(line)
            else:
                result_lines.append(line)

        if result_lines:
            return '\n'.join(result_lines)

        return answer

    def _convert_markdown_to_template(self, answer: str) -> str:
        """
        将 markdown 格式转换为三段式模板格式

        处理 DeepSeek-R1 输出的 markdown 格式（##、### 标题）
        转换为标准的 【直接回答】【详细说明】【数据来源】格式
        """
        import re

        # 如果已经包含模板标记，直接返回
        if '【直接回答】' in answer:
            return answer

        # 移除思考过程标记
        answer = re.sub(r'\.\.\.done thinking\.', '', answer, flags=re.IGNORECASE)

        # 按行分割
        lines = answer.split('\n')

        # 提取内容
        direct_answer_parts = []
        detail_parts = []
        source_parts = []

        current_section = None  # 'direct', 'detail', 'source'

        for line in lines:
            line = line.strip()
            if not line:
                continue

            # 检测 markdown 标题级别
            if line.startswith('###'):
                content = line[3:].strip()
                if content == '直接回答' or '直接回答' in content or '推荐套餐' in content or '答案' in content:
                    current_section = 'direct'
                elif content == '详细说明' or '详细说明' in content or '说明' in content:
                    current_section = 'detail'
                elif content == '数据来源' or '数据来源' in content or '来源' in content:
                    current_section = 'source'
                else:
                    # 其他三级标题，根据内容判断
                    if '套餐' in content and '推荐' in content:
                        current_section = 'direct'
                    elif any(x in content for x in ['说明', '包含', '资费', '流量']):
                        current_section = 'detail'
                    elif any(x in content for x in ['来源', '文档']):
                        current_section = 'source'
                    else:
                        direct_answer_parts.append(content)
            elif line.startswith('##'):
                content = line[2:].strip()
                if '套餐' in content or '推荐' in content or '直接' in content:
                    current_section = 'direct'
                    direct_answer_parts.append(content.replace('##', '').strip())
                elif '说明' in content or '详情' in content or '包含' in content:
                    current_section = 'detail'
                elif '来源' in content:
                    current_section = 'source'
                else:
                    direct_answer_parts.append(content)
            elif line.startswith('#'):
                # 一级标题，通常是推荐或总结
                content = line[1:].strip()
                current_section = 'direct'
                direct_answer_parts.append(content)
            elif line.startswith('- ') or line.startswith('* '):
                # 列表项
                content = line[2:].strip()
                if current_section == 'source':
                    source_parts.append(content)
                elif current_section == 'direct':
                    direct_answer_parts.append(content)
                else:
                    detail_parts.append(content)
            elif line.startswith('1.') or line.startswith('2.') or line.startswith('3.'):
                # 数字列表
                if current_section == 'direct' or current_section is None:
                    direct_answer_parts.append(line)
                else:
                    detail_parts.append(line)
            else:
                # 普通文本
                if current_section == 'direct' or current_section is None:
                    direct_answer_parts.append(line)
                elif current_section == 'detail':
                    detail_parts.append(line)
                elif current_section == 'source':
                    source_parts.append(line)

        # 构建标准格式答案
        if not direct_answer_parts:
            direct_answer_parts.append("根据知识库中的文档，请参考详细信息。")

        if not detail_parts:
            detail_parts = direct_answer_parts.copy()

        if not source_parts:
            source_parts = ["相关政策文档"]

        # 组装答案
        direct_answer = ' '.join(direct_answer_parts[:3])  # 最多3句话
        detail = ' '.join(detail_parts[:10])  # 最多10句话

        result = f"""【直接回答】
{direct_answer}

【详细说明】
{detail}

【数据来源】
"""
        for source in source_parts[:5]:
            result += f"- {source}\n"

        return result

    def _build_context(
        self,
        docs: List[Dict],
        analysis: Dict,
        reasoning_steps: List[str],
        is_knowledge_base_query: bool,
        original_query: str = None,
        is_followup: bool = False,
        chat_history: list = None
    ) -> str:
        """构建上下文（增强版 - 约束条件 + 表格解析 + 优化格式化 + 枚举增强 + 追问增强）"""
        context_parts = []

        # Phase 1: 提取约束条件
        constraints_text = ""
        if USE_CONSTRAINT_EXTRACTOR and self.constraint_extractor and docs:
            try:
                constraints = self.constraint_extractor.extract_from_documents(docs)
                if constraints and original_query:
                    relevant_constraints = self.constraint_extractor.get_relevant_constraints(
                        original_query, "", constraints
                    )
                    if relevant_constraints:
                        constraints_text = self.constraint_extractor.format_constraints_for_prompt(
                            relevant_constraints[:10]
                        )
                        logger.info(f"添加了 {len(relevant_constraints)} 个相关约束条件")
            except Exception as e:
                logger.warning(f"约束提取失败: {e}")

        # 方案3: 提取条件、限制、要求信息
        conditions_text = ""
        if USE_CONDITION_EXTRACTOR and self.condition_extractor and docs and original_query:
            try:
                logger.info(f"🔧 方案3: 开始提取条件，文档数={len(docs)}, 查询={original_query[:50]}")
                conditions = self.condition_extractor.extract_conditions(docs, original_query)
                logger.info(f"🔧 方案3: 提取到 {len(conditions)} 个条件")
                if conditions:
                    conditions_text = self.condition_extractor.format_conditions_for_llm(conditions)
                    logger.info(f"🔧 方案3: 格式化后文本长度={len(conditions_text)}")
                    if len(conditions_text) > 0:
                        logger.info(f"🔧 方案3: 成功添加 {len(conditions)} 个条件、限制、要求")
                    else:
                        logger.warning("🔧 方案3: 格式化后文本为空")
                else:
                    logger.warning("🔧 方案3: 条件列表为空")
            except Exception as e:
                logger.error(f"🔧 方案3: 条件提取失败: {e}", exc_info=True)
        else:
            logger.debug(f"🔧 方案3: 跳过条件提取 - USE={USE_CONDITION_EXTRACTOR}, extractor={self.condition_extractor is not None}, docs={len(docs) if docs else 0}, query={bool(original_query)}")

        # Phase 1: 解析表格数据
        tables_text = ""
        if USE_TABLE_PARSER and self.table_parser and docs:
            try:
                from services.universal_table_parser import extract_tables_from_documents
                tables = extract_tables_from_documents(docs, self.table_parser)
                if tables:
                    tables_text = self.table_parser.format_for_prompt(tables[:3])
                    logger.info(f"解析了 {len(tables)} 个表格")
            except Exception as e:
                logger.warning(f"表格解析失败: {e}")

        # 检查是否包含表格数据并优化格式化
        has_table_data = False
        table_info = None

        if docs:
            for doc in docs[:10]:
                doc_text = doc.get("text", "")
                # 检测表格数据标记
                if "## 表格对比数据" in doc_text or "## 表格" in doc_text:
                    has_table_data = True
                    # 优化表格数据格式
                    if "表格对比数据" in doc_text:
                        # 确保表格数据有清晰的说明
                        if "【数据说明】" not in doc_text:
                            doc_text = doc_text.replace(
                                "## 表格对比数据",
                                "## 表格对比数据\n\n【数据说明】\n- 这是一个转置表格，第一列是指标名称，后续列是不同类别的数值\n- 下面列出每个指标在不同类别中的数值\n\n【列名对应关系】\n- 请仔细阅读每个类别对应的数值"
                            )
                    break

        # Phase 1: 添加约束条件（在文档内容之前）
        if constraints_text:
            context_parts.append(constraints_text)
            context_parts.append("")

        # 方案3: 添加条件、限制、要求信息（在文档内容之前）
        if conditions_text:
            context_parts.append(conditions_text)
            context_parts.append("")

        # Phase 1: 添加表格数据（在文档内容之前）
        if tables_text:
            context_parts.append(tables_text)
            context_parts.append("")

        # 添加检索到的文档内容
        if docs:
            context_parts.append("## 检索到的文档内容\n")
            for i, doc in enumerate(docs[:10]):  # 限制最多10个文档
                doc_text = doc.get("text", "")
                source = doc.get("source_document",
                               doc.get("metadata", {}).get("filename",
                               doc.get("filename", "unknown")))
                if doc_text:
                    # 限制单个文档长度
                    max_doc_length = 1500 if has_table_data else 1000
                    if len(doc_text) > max_doc_length:
                        doc_text = doc_text[:max_doc_length] + "...(已截断)"
                    context_parts.append(f"### 文档 {i+1}: {source}")
                    context_parts.append(f"{doc_text}")
                    context_parts.append("")  # 空行分隔

        # 添加数据来源文档名称列表
        if docs:
            actual_doc_names = sorted(set(
                doc.get("source_document",
                       doc.get("metadata", {}).get("filename",
                       doc.get("filename", "unknown"))) for doc in docs
            ))
            context_parts.append("\n## 数据来源文档名称")
            for doc_name in actual_doc_names:
                context_parts.append(f"- {doc_name}")

        # 添加分析结果（包括精确计算结果）
        if analysis:
            context_parts.append("\n## 分析结果")
            if analysis.get("type"):
                context_parts.append(f"分析类型: {analysis['type']}")

            # 重要：如果是计算类型，添加精确计算结果
            if analysis.get("type") == "calculation":
                if analysis.get("calculation"):
                    context_parts.append(f"**精确计算公式**: {analysis['calculation']}")
                if analysis.get("calculation_result") is not None:
                    context_parts.append(f"**计算结果**: {analysis['calculation_result']}")
                    context_parts.append(f"**重要提示**: 上述计算已由专门计算工具精确完成，请直接使用此结果，不要重新计算！")
                if analysis.get("data_points"):
                    context_parts.append("**数据来源**:")
                    for dp in analysis.get("data_points", [])[:3]:
                        context_parts.append(f"  - {dp[:150]}...")

        # 构建基础上下文
        base_context = "\n".join(context_parts)

        # 枚举增强：如果检测到枚举类问题，增强上下文
        if original_query and self.enumeration_enhancer:
            is_enumeration = self.enumeration_enhancer.is_enumeration_question(original_query)
            if is_enumeration:
                base_context = self.enumeration_enhancer.enhance_context_for_enumeration(
                    base_context, original_query
                )

        # 追问增强：如果检测到追问，添加对话上下文
        if is_followup and self.context_enhancer and original_query:
            base_context = self.context_enhancer.build_enhanced_context(
                chat_history, original_query, base_context
            )

        # 关键数值完整性增强：高亮显示容易被遗漏的数值
        if self.critical_checker and original_query:
            base_context = self.critical_checker.highlight_critical_values_in_context(
                base_context, original_query
            )

        return base_context

    def _build_dynamic_prompt(
        self,
        original_query: str,
        context: str,
        intent: str,
        has_table_data: bool = False
    ) -> tuple:
        """
        动态构建优化的提示词

        Args:
            original_query: 用户原始查询
            context: 检索上下文
            intent: 意图类型
            has_table_data: 是否包含表格数据

        Returns:
            (system_prompt, user_prompt) 元组
        """
        if USE_OPTIMIZED_PROMPTS and OptimizedPromptService:
            # 检测查询类型
            query_type = None

            # 优先检测数值查询
            if any(kw in original_query for kw in NUMERIC_QUERY_KEYWORDS):
                if any(kw in original_query for kw in ["结构", "对比", "不同", "差异"]):
                    query_type = QueryType.NUMERIC
                elif any(kw in original_query for kw in ["费用", "手续费", "分成", "激励", "多少"]):
                    query_type = QueryType.NUMERIC

            # 检测其他类型
            if query_type is None:
                if has_table_data or "表格" in context:
                    query_type = QueryType.TABLE
                elif "对比" in original_query or "差异" in original_query or "分别" in original_query:
                    query_type = QueryType.COMPARISON
                elif "计算" in original_query or "合计" in original_query or "总计" in original_query:
                    query_type = QueryType.CALCULATION
                else:
                    query_type = QueryType.SIMPLE

            # 检查缓存
            cache_key = f"{query_type}_{has_table_data}_{original_query[:30]}"
            if cache_key in self._prompt_cache:
                return self._prompt_cache[cache_key]

            # 构建优化的提示词
            system_prompt = self._build_system_prompt(use_optimized=True)

            # 为不同查询类型添加额外说明
            if query_type == QueryType.NUMERIC:
                system_prompt += """

## ⚠️ 数值精确提取特别说明：
- 必须提取完整的数值+单位（如：75元、50元、11.7元、19.5元、T1+T2）
- 对比类问题必须为每个类别列出具体数值
- 格式要求：满足条件A = XX元，不满足条件B = XX元
- 禁止使用"包含费用"等模糊表述，必须给出具体数字
- 从表格中逐字逐句提取数值，不要遗漏任何关键数据"""

            elif query_type == QueryType.TABLE or has_table_data:
                system_prompt += """

## 表格数据解析特别说明：
- 仔细阅读列名含义，不要混淆列名和数据值
- 对于对比类表格，明确指出"哪个类别"对应"哪个数值"
- 注意数值的单位（元、%、月等）"""

            user_prompt = f"问题：{original_query}\n\n{context}"

            # 缓存
            self._prompt_cache[cache_key] = (system_prompt, user_prompt)
            return system_prompt, user_prompt

        else:
            # 使用默认方法
            return self.system_prompt, f"请根据以下上下文回答用户问题：\n\n查询：{original_query}\n\n上下文：\n{context}"

    async def _generate_answer(
        self,
        original_query: str,
        rewritten_query: str,
        context: str,
        intent: str,
        chat_history: list = None,
        is_enumeration: bool = False,
        is_followup: bool = False,
        docs: List[Dict] = None  # Phase 2: 添加docs参数用于验证
    ) -> str:
        """
        使用LLM生成答案（优化版 - 使用动态提示词 + 枚举增强 + 追问增强）

        Args:
            original_query: 用户原始查询
            rewritten_query: 上下文重写后的查询
            context: 检索到的上下文
            intent: 意图类型
            chat_history: 对话历史
            is_enumeration: 是否为枚举类问题
            is_followup: 是否为追问
        """
        # 检测是否包含表格数据
        has_table_data = "## 表格对比数据" in context or "表格结构" in context

        # 构建对话历史上下文（压缩+清理格式）
        history_context = ""
        if chat_history and len(chat_history) > 0:
            recent_history = chat_history[-4:]  # 减少到4轮以节省tokens
            history_items = []
            for msg in recent_history:
                role = msg.get("role", "user")
                content = msg.get("content", "")

                # 关键修复：对于assistant回复，移除格式标记以避免LLM模仿
                if role == "assistant":
                    # 提取【直接回答】部分的核心内容，移除所有格式标记
                    import re
                    direct_match = re.search(r"【直接回答】\s*([^\【\n]+)", content)
                    if direct_match:
                        # 只保留直接回答的核心信息，去掉格式
                        content = direct_match.group(1).strip()[:100]
                    else:
                        # 如果没有标记，截取前100字符
                        content = content[:100] + "..." if len(content) > 100 else content

                    # 移除所有格式标记
                    content = re.sub(r"【[^】]+】", "", content)
                    content = content.strip()

                # 对于用户消息，也进行压缩
                elif role == "user" and len(content) > 100:
                    content = content[:80] + "..."

                if content:  # 只添加非空内容
                    history_items.append(f"{role}: {content}")

            if history_items:
                history_context = f"\n## 对话历史\n" + "\n".join(history_items) + "\n"

        # 如果原始查询和重写查询不同
        query_context = ""
        if original_query != rewritten_query:
            query_context = f"用户问题：{original_query}\n理解：{rewritten_query}\n"
            logger.info(f"🎯 上下文重写: '{original_query}' -> '{rewritten_query}'")
            logger.info(f"ℹ️ 无上下文重写: query='{original_query}'")

        # 使用动态提示词构建
        system_prompt, base_user_prompt = self._build_dynamic_prompt(
            original_query=rewritten_query,
            context=context,
            intent=intent,
            has_table_data=has_table_data
        )

        # 添加业务规则澄清提示
        if USE_BUSINESS_CLARIFIER:
            enhanced_prompt = build_enhanced_prompt(rewritten_query, system_prompt)
            if enhanced_prompt != system_prompt:
                system_prompt = enhanced_prompt
                logger.info("✅ 已添加业务规则澄清提示")

        # 枚举增强：添加枚举类问题的特殊提示
        if is_enumeration and self.enumeration_enhancer:
            enum_prompt = self.enumeration_enhancer.build_enumeration_prompt(
                original_query, context
            )
            system_prompt += "\n" + enum_prompt
            logger.info("已添加枚举类问题增强提示词")

        # 关键数值完整性提示：添加容易遗漏数值的特别提醒
        if self.critical_checker:
            critical_prompt = self.critical_checker.build_completeness_prompt(
                context, original_query
            )
            if critical_prompt.strip():  # 只有在有内容时才添加
                system_prompt += "\n" + critical_prompt
                logger.info("已添加关键数值完整性提示词")

        # 构建完整的用户消息
        if query_context:
            user_content = f"{query_context}\n{base_user_prompt}"
        else:
            user_content = base_user_prompt

        if history_context:
            user_content = f"{user_content}\n{history_context}"

        messages = [
            SystemMessage(content=system_prompt),
            HumanMessage(content=user_content)
        ]

        # 尝试多次连接（增强稳定性）
        max_retries = 3
        retry_delay = 1

        for attempt in range(max_retries):
            try:
                logger.info(f"GenerateAgent: 尝试LLM连接 (第{attempt + 1}次)...")

                # 一次性生成完整答案（两段式）
                user_prompt = f"""请基于以下文档内容回答用户问题，使用列表格式。

问题：{original_query}

参考文档：
{context}

【答案格式】
【回答】
• [使用项目符号，列出所有相关项目]
• [项目1]
• [项目2]
...

【数据来源】
• [文档名称]

注意：
1. 使用项目符号（•），不要使用数字列表
2. 不要使用markdown格式
3. 列出所有相关信息
"""

                messages = [
                    SystemMessage(content="你是中国移动渠道业务专家。"),
                    HumanMessage(content=user_prompt)
                ]

                response = await self.llm.ainvoke(messages)
                answer = response.content.strip()

                if not answer:
                    answer = "抱歉，我无法基于提供的上下文生成答案。"

                # 移除 DeepSeek-R1 的思考过程
                answer = self._remove_thinking_process(answer)

                # 转换 markdown 格式为模板格式
                answer = self._convert_markdown_to_template(answer)

                # 验证并修复答案格式
                answer = self._validate_and_fix_format(answer, context)

                # Phase 1: 答案验证
                if USE_ANSWER_VALIDATOR and self.answer_validator:
                    try:
                        # Phase 3: 添加关键操作日志
                        logger.info("=" * 60)
                        logger.info("🔍 [Phase 3] 开始验证答案")

                        # 提取约束条件用于验证
                        constraints = []
                        if USE_CONSTRAINT_EXTRACTOR and self.constraint_extractor and docs:
                            logger.info(f"📊 [Phase 3] 约束提取器状态: 已加载")
                            constraints = self.constraint_extractor.extract_from_documents(docs)

                            # Phase 3: 记录列表类约束
                            list_constraints = [c for c in constraints if hasattr(c, 'items') and c.items]
                            if list_constraints:
                                logger.info(f"📋 [Phase 3] 列表类约束: {len(list_constraints)} 个")
                                for c in list_constraints:
                                    logger.info(f"   - {c.condition}: {len(c.items)} 项")

                        logger.info(f"📊 [Phase 3] 表格解析器状态: {'已加载' if self.table_parser else '未加载'}")
                        logger.info(f"📊 [Phase 3] 答案验证器状态: {'已加载' if self.answer_validator else '未加载'}")

                        # 执行业务规则验证
                        if USE_BUSINESS_CLARIFIER:
                            # 验证59元套餐完整性
                            if "59元" in original_query or "潮玩青春卡" in original_query:
                                package_validation = validate_answer_59_package(answer)
                                if not package_validation["is_complete"]:
                                    logger.warning(f"⚠️ 59元套餐答案不完整，缺失: {package_validation['missing_items']}")

                            # 验证费用计算完整性
                            pricing_validation = validate_answer_pricing(answer)
                            if pricing_validation["has_issues"]:
                                logger.warning(f"⚠️ 费用计算答案存在问题: {pricing_validation['issues']}")

                            # 验证新入网优惠混淆
                            if "新入网" in original_query or "7折" in original_query or "流量赠送" in original_query:
                                customer_validation = validate_answer_new_customer(answer, original_query)
                                if customer_validation["has_confusion"]:
                                    logger.warning(f"⚠️ 新入网优惠概念混淆: {customer_validation['confusion_issues']}")

                        # 执行验证
                        validation_result = self.answer_validator.validate(
                            answer=answer,
                            question=original_query,
                            context=context,
                            constraints=constraints
                        )

                        logger.info(f"答案验证得分: {validation_result.score:.1f}/100, "
                                  f"问题数: {len(validation_result.issues)}")

                        # Phase 3: 自动修正机制 - 始终尝试时间周期修正（不依赖分数）
                        # 时间周期错误是关键问题，即使整体分数较高也需要修正
                        should_correct = False
                        if USE_CONSTRAINT_EXTRACTOR and self.constraint_extractor:
                            # Phase 3 诊断：记录上下文片段
                            context_snippet = context[:300] if context else ""
                            logger.info(f"🔍 [Phase 3 诊断] 上下文片段: {context_snippet[:200]}...")

                            is_accurate, error_msg = self.constraint_extractor.validate_time_period_accuracy(answer, context)
                            if not is_accurate:
                                logger.info(f"🔧 [Phase 3] 检测到时间周期错误，启用自动修正: {error_msg}")
                                should_correct = True
                            else:
                                logger.info(f"ℹ️ [Phase 3] 时间周期验证通过，无需修正")

                        # 如果分数较低也有其他问题，也进行自动修正
                        if validation_result.score < 80 and len(validation_result.issues) > 0:
                            logger.info(f"🔧 [Phase 3] 验证得分较低，启用全面自动修正")
                            should_correct = True

                        if should_correct:
                            logger.info(f"🔧 [Phase 3] 尝试自动修正答案...")
                            corrected_answer = self._auto_correct_answer(
                                answer, original_query, context, validation_result, constraints
                            )
                            if corrected_answer != answer:
                                logger.info(f"✅ [Phase 3] 答案已自动修正")
                                answer = corrected_answer
                                # 重新验证修正后的答案
                                validation_result = self.answer_validator.validate(
                                    answer=answer,
                                    question=original_query,
                                    context=context,
                                    constraints=constraints
                                )
                                logger.info(f"修正后验证得分: {validation_result.score:.1f}/100")

                        # 如果验证未通过且得分过低，尝试重新生成（仅一次）
                        should_regenerate, reason = self.answer_validator.should_regenerate(validation_result)
                        if should_regenerate and attempt == 0:
                            logger.info(f"答案质量不佳，尝试重新生成: {reason}")

                            # 在系统提示中添加验证反馈
                            retry_system_prompt = system_prompt + f"""

## ⚠️ 上次答案质量问题反馈：
{self.answer_validator.format_validation_result(validation_result)}

请根据上述反馈改进你的答案！"""

                            messages = [
                                SystemMessage(content=retry_system_prompt),
                                HumanMessage(content=user_content)
                            ]

                            response = await self.llm.ainvoke(messages)
                            answer = response.content.strip()
                            answer = self._remove_thinking_process(answer)
                            answer = self._convert_markdown_to_template(answer)
                            answer = self._validate_and_fix_format(answer, context)

                    except Exception as e:
                        logger.warning(f"答案验证失败: {e}")

                logger.info(f"GenerateAgent: LLM响应长度: {len(answer)} 字符")
                return answer

            except Exception as e:
                logger.warning(f"GenerateAgent: 第{attempt + 1}次尝试失败: {str(e)[:100]}")

                if attempt == max_retries - 1:
                    logger.warning("GenerateAgent: 所有尝试失败，使用降级答案")
                    return "抱歉，我无法基于提供的上下文生成答案。请确保文档已正确上传并处理完成。"
                else:
                    import asyncio
                    await asyncio.sleep(retry_delay)
                    continue

        return "抱歉，我无法基于提供的上下文生成答案。"

    def _generate_simple_answer(self, docs: List[Dict], analysis: Dict) -> str:
        """生成简单答案（降级用）- 使用两段式模板"""
        if not docs:
            return """【直接回答】
抱歉，知识库中没有找到相关文档。请确保文档已正确上传并处理完成，如果问题涉及具体业务场景，请提供更多上下文信息。

【数据来源】
• 暂无"""

        doc_names = []
        for doc in docs:
            name = doc.get("source_document",
                          doc.get("metadata", {}).get("filename",
                          doc.get("filename", "unknown")))
            if name != "unknown":
                doc_names.append(name)

        if not doc_names:
            return """【直接回答】
抱歉，我无法基于提供的上下文生成答案。检索到的文档中可能不包含您询问的信息，建议重新描述问题或确认文档已正确上传。

【数据来源】
• 暂无相关文档"""

        doc_list = "、".join(list(set(doc_names))[:3])
        sources = "\n".join([f"• {name}" for name in list(set(doc_names))[:3]])

        return f"""【直接回答】
在知识库中找到了相关文档：{doc_list}。建议您在这些文档中查找具体的业务规则和数据。

【数据来源】
{sources}"""

    def _fix_answer_format(self, answer: str) -> str:
        """
        修复答案格式问题

        修复常见的格式错误：
        1. 【直接回答】。 -> 【直接回答】\n
        2. 【数据来源】。 -> 【数据来源】\n
        3. 确保各部分之间有正确的换行

        Args:
            answer: 原始答案

        Returns:
            格式修正后的答案
        """
        import re

        logger.info(f"🔧 [Format Fix] _fix_answer_format called, answer length={len(answer)}")
        logger.info(f"🔧 [Format Fix] Before: {repr(answer[:200])}")

        fixed = answer

        # 1. 修复标记后的句号问题：【标记】。 -> 【标记】\n
        # 但要小心不要移除内容中的句号
        logger.info("🔧 [Format Fix] Applying regex patterns...")
        fixed = re.sub(r'【直接回答】。\s*', '【直接回答】\n', fixed)
        logger.info(f"🔧 [Format Fix] After direct_answer fix: {repr(fixed[:100])}")
        fixed = re.sub(r'【数据来源】。\s*', '【数据来源】\n', fixed)
        logger.info(f"🔧 [Format Fix] After source fix: {repr(fixed[:200])}")

        # 2. 确保各标记后有换行（如果没有句号的情况）
        fixed = re.sub(r'【直接回答】([^\n])', r'【直接回答】\n\1', fixed)
        fixed = re.sub(r'【数据来源】([^\n])', r'【数据来源】\n\1', fixed)

        # 3. 确保各部分之间有空行分隔
        fixed = re.sub(r'([^\n])\n【', r'\1\n\n【', fixed)

        # 4. 移除过多的连续空行
        fixed = re.sub(r'\n{3,}', '\n\n', fixed)

        # 5. 去除开头和结尾的空白
        fixed = fixed.strip()

        # 如果格式修复后内容有明显变化，记录日志
        if fixed != answer:
            logger.info(f"📝 [Format Fix] 已修复答案格式")
            logger.debug(f"修复前: {repr(answer[:200])}")
            logger.debug(f"修复后: {repr(fixed[:200])}")

        return fixed

    def _validate_and_fix_format(self, answer: str, context: str) -> str:
        """
        验证并修复答案格式

        使用两段式格式：【直接回答】【数据来源】

        Args:
            answer: 原始答案
            context: 上下文内容

        Returns:
            格式化后的答案
        """
        import re

        # 首先修复格式问题（处理句号和换行问题）
        answer = self._fix_answer_format(answer)

        # 检查是否已经包含正确的格式标记
        has_direct = "【直接回答】" in answer
        has_sources = "【数据来源】" in answer

        # 使用两段式格式
        has_valid_format = has_direct and has_sources

        if has_valid_format:
            # 格式正确，直接返回
            return answer

        # 检测是否有问答对格式（问题1-6常见问题）
        qa_patterns = [
            r'问题\d*[：:]\s*',
            r'Q\d*[：:]\s*',
            r'问\d*[：:]\s*',
            r'追问\d*[：:]\s*',
        ]

        has_qa_format = any(re.search(pattern, answer) for pattern in qa_patterns)

        if has_qa_format:
            # 需要重新格式化问答对为标准格式
            return self._convert_qa_to_standard_format(answer, context)

        # 检测是否完全没有格式
        if not has_valid_format and not has_qa_format:
            # 尝试提取答案内容并添加格式
            return self._wrap_with_standard_format(answer, context)

        return answer

    def _convert_qa_to_standard_format(self, qa_answer: str, context: str) -> str:
        """
        将问答对格式转换为标准格式

        Args:
            qa_answer: 问答对格式的答案
            context: 上下文

        Returns:
            标准格式答案
        """
        import re

        # 提取所有答案部分
        lines = qa_answer.split('\n')
        answer_parts = []

        for line in lines:
            line = line.strip()
            if not line or line.startswith('问题') or line.startswith('问') or line.startswith('Q') or line.startswith('追问'):
                continue
            # 跳过问题标记行
            if re.match(r'^(问题|问|Q|追问)\d*[：:]', line):
                continue
            # 如果包含"答案："标记，提取答案内容
            if '答案：' in line or '答案:' in line:
                parts = re.split(r'答案[：:]', line, 1)
                if len(parts) > 1:
                    answer_parts.append(parts[1].strip())
            else:
                answer_parts.append(line)

        # 构建标准格式（不再限制答案部分数量）
        direct_answer = '\n'.join(answer_parts) if answer_parts else "请参考文档内容"

        # 提取文档名称
        doc_names = re.findall(r'### 文档 \d+: ([^\n]+)', context)
        if not doc_names:
            doc_names = re.findall(r'文档[：:]\s*([^\n]+)', context)
        doc_names = list(set(doc_names))[:3]

        sources = "\n".join([f"• {name}" for name in doc_names]) if doc_names else "• 相关政策文档"

        return f"""【直接回答】
{direct_answer}

【数据来源】
{sources}"""

    def _wrap_with_standard_format(self, answer: str, context: str) -> str:
        """
        将无格式答案包装为标准格式

        Args:
            answer: 原始答案
            context: 上下文

        Returns:
            标准格式答案
        """
        # 提取文档名称
        doc_names = re.findall(r'### 文档 \d+: ([^\n]+)', context)
        if not doc_names:
            doc_names = re.findall(r'文档[：:]\s*([^\n]+)', context)
        doc_names = list(set(doc_names))[:3]

        sources = "\n".join([f"• {name}" for name in doc_names]) if doc_names else "• 相关政策文档"

        # 清理答案内容（不再截断）
        clean_answer = answer.strip()

        return f"""【直接回答】
{clean_answer}

【数据来源】
{sources}"""

    def _auto_correct_answer(
        self,
        answer: str,
        question: str,
        context: str,
        validation_result,
        constraints: List
    ) -> str:
        """
        Phase 3 新增：根据验证结果自动修正答案

        处理可自动修正的问题：
        1. 时间周期错误（T1-T12 → T+3-T+12）
        2. 列表遗漏（补充缺失的列表项）

        Args:
            answer: 原始答案
            question: 用户问题
            context: 上下文
            validation_result: 验证结果
            constraints: 约束条件列表

        Returns:
            修正后的答案
        """
        import re
        corrected = answer
        logger.info(f"🔍 [Phase 3] 开始自动修正，原始答案: {answer[:100]}...")

        # 1. 修正时间周期错误（通用方法，不硬编码）
        if USE_CONSTRAINT_EXTRACTOR and self.constraint_extractor:
            logger.info(f"🔍 [Phase 3] 调用 validate_time_period_accuracy...")
            is_accurate, error_msg = self.constraint_extractor.validate_time_period_accuracy(answer, context)
            logger.info(f"🔍 [Phase 3] 时间周期验证结果: is_accurate={is_accurate}, error_msg={error_msg}")
            if not is_accurate:
                logger.info(f"🔧 [Phase 3] 时间周期不准确，开始修正...")
                corrected = self._correct_time_period_in_answer(corrected, context)
                logger.info(f"✅ [Phase 3] 已修正时间周期: {error_msg}")
            else:
                logger.info(f"ℹ️ [Phase 3] 时间周期验证通过，无需修正")

        # 2. 补充缺失的列表项
        if constraints:
            list_constraints = [c for c in constraints if hasattr(c, 'items') and c.items]
            if list_constraints:
                corrected = self._add_missing_list_items(corrected, list_constraints)
                missing_count = self._count_missing_items(corrected, list_constraints)
                if missing_count > 0:
                    logger.info(f"🔧 [Phase 3] 已补充 {missing_count} 个缺失列表项")

        return corrected

    def _correct_time_period_in_answer(self, answer: str, context: str) -> str:
        """
        修正答案中的时间周期

        Phase 3 修复：支持替换任何 T+n至T+m 格式的错误周期
        """
        import re

        logger.info(f"🔍 [Phase 3] _correct_time_period_in_answer 被调用")
        logger.info(f"🔍 [Phase 3] answer 长度: {len(answer)}, context 长度: {len(context)}")

        # 从上下文中提取正确的时间周期
        correct_periods = []
        # T+n 至 T+m 格式
        matches = re.finditer(r'T\+(\d+)\s*至\s*T\+(\d+)', context)
        for m in matches:
            correct_periods.append({
                'start': int(m.group(1)),
                'end': int(m.group(2)),
                'text': f"T+{m.group(1)}至T+{m.group(2)}"
            })

        # Tn-Tm 格式（需要转换为 T+n）
        matches = re.finditer(r'T(\d+)\s*(?:至|-|~)\s*T(\d+)', context)
        for m in matches:
            correct_periods.append({
                'start': int(m.group(1)),
                'end': int(m.group(2)),
                'text': f"T+{m.group(1)}至T+{m.group(2)}"
            })

        if not correct_periods:
            logger.info(f"📅 [Phase 3] 上下文中未找到时间周期，context片段: {context[:200]}...")
            return answer

        # 使用最长的时间周期（通常是最完整的描述）
        correct_period = max(correct_periods, key=lambda p: p['end'] - p['start'])
        logger.info(f"📅 [Phase 3] 从上下文提取正确周期: {correct_period['text']}")
        for m in matches:
            correct_periods.append({
                'start': int(m.group(1)),
                'end': int(m.group(2)),
                'text': f"T+{m.group(1)}至T+{m.group(2)}"
            })

        if not correct_periods:
            logger.info("📅 [Phase 3] 上下文中未找到时间周期，跳过修正")
            return answer

        # 使用最长的时间周期（通常是最完整的描述）
        correct_period = max(correct_periods, key=lambda p: p['end'] - p['start'])
        logger.info(f"📅 [Phase 3] 从上下文提取正确周期: {correct_period['text']}")

        corrected = answer

        # Phase 3 修复：替换答案中的任何 T+n至T+m 格式（不仅是特定模式）
        # 匹配 T+n至T+m 或 Tn至Tm 或 Tn-Tm 等各种变体
        answer_period_patterns = [
            r'T\+\d+\s*至\s*T\+\d+',  # T+3至T+12
            r'T\+\d+\s*[-~]\s*T\+\d+',  # T+3-T+12
            r'T\d+\s*至\s*T\d+',  # T3至T12
            r'T\d+\s*[-~]\s*T\d+',  # T3-T12
        ]

        for pattern in answer_period_patterns:
            if re.search(pattern, corrected):
                logger.info(f"🔧 [Phase 3] 检测到答案中的时间周期，使用: {correct_period['text']}")
                corrected = re.sub(pattern, correct_period['text'], corrected)
                logger.info(f"✅ [Phase 3] 时间周期已修正: {corrected != answer}")
                break
        else:
            logger.info(f"⚠️ [Phase 3] 答案中未找到时间周期模式")

        return corrected

    def _add_missing_list_items(self, answer: str, list_constraints: List) -> str:
        """补充缺失的列表项到答案中"""
        import re

        corrected = answer

        for constraint in list_constraints:
            if not constraint.items:
                continue

            missing_items = []
            for item in constraint.items:
                # 🔧 修复：过滤掉表格格式的长文本（包含 | 或 prod. 的表格行）
                if '|' in item or 'prod.' in item.lower() or len(item) > 100:
                    logger.info(f"⚠️ [Phase 3] 跳过表格格式数据: {item[:50]}...")
                    continue

                # 🔧 修复：使用更智能的匹配 - 检查关键词是否存在
                # 提取item的关键词（去掉数字、单位等）
                item_keywords = re.sub(r'\d+|[元个GB%]| prod\.|JYPT', '', item.lower())
                item_keywords = ' '.join(item_keywords.split())

                # 检查答案中是否包含关键词
                if item_keywords and len(item_keywords) > 3:
                    # 简化的关键词检查
                    main_keyword = item_keywords.split()[0] if item_keywords.split() else item_keywords[:10]
                    if main_keyword not in answer.lower():
                        missing_items.append(item)
                elif item.lower() not in answer.lower():
                    # 如果没有提取到关键词，使用原来的方法
                    missing_items.append(item)

            if missing_items:
                # 🔧 修复：限制补充内容的数量和长度
                valid_items = [item for item in missing_items if len(item) < 50][:3]

                if valid_items:
                    # 在详细说明中补充缺失项
                    supplement = f"补充：还包括{', '.join(valid_items)}"
                    if len(missing_items) > len(valid_items):
                        supplement += f" 等{len(missing_items)}项"

                    # 🔧 修复：检查是否已经存在"补充：还包括"内容，避免重复
                    if '补充：还包括' not in corrected:
                        # 找到【详细说明】部分并添加
                        if '【详细说明】' in corrected:
                            parts = corrected.split('【详细说明】', 1)
                            if len(parts) == 2:
                                detail_section = parts[1]
                                if '【数据来源】' in detail_section:
                                    detail_parts = detail_section.split('【数据来源】', 1)
                                    corrected = f"{parts[0]}【详细说明】{detail_parts[0]}\n{supplement}\n【数据来源】{detail_parts[1]}"
                                else:
                                    corrected = f"{parts[0]}【详细说明】{detail_section}\n{supplement}"
                    else:
                        logger.info(f"ℹ️ [Phase 3] 答案中已存在补充内容，跳过添加")

        return corrected

    def _count_missing_items(self, answer: str, list_constraints: List) -> int:
        """统计缺失的列表项数量"""
        import re
        count = 0

        for constraint in list_constraints:
            if constraint.items:
                for item in constraint.items:
                    # 🔧 修复：过滤掉表格格式的长文本
                    if '|' in item or 'prod.' in item.lower() or len(item) > 100:
                        continue

                    # 🔧 修复：使用与 _add_missing_list_items 相同的判断逻辑
                    item_keywords = re.sub(r'\d+|[元个GB%]| prod\.|JYPT', '', item.lower())
                    item_keywords = ' '.join(item_keywords.split())

                    if item_keywords and len(item_keywords) > 3:
                        main_keyword = item_keywords.split()[0] if item_keywords.split() else item_keywords[:10]
                        if main_keyword not in answer.lower():
                            count += 1
                    elif item.lower() not in answer.lower():
                        count += 1

        return count

    def _calculate_confidence(self, state: AgentState) -> float:
        """计算置信度"""
        # 基于检索到的文档数量和质量
        docs = state.get("retrieved_docs", [])
        has_answer = bool(state.get("draft_answer", ""))

        # 基础分
        base_score = 0.3

        # 根据文档数量加分
        if len(docs) > 0:
            base_score += 0.3

        if len(docs) >= 3:
            base_score += 0.1

        # 答案完整性加分
        if has_answer:
            base_score += 0.3

        return min(base_score, 1.0)


def create_generate_agent(llm: ChatOllama) -> GenerateAgent:
    """创建GenerateAgent实例"""
    return GenerateAgent(llm=llm)
